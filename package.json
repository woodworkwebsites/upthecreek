{
  "name": "up-the-creek-padel",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n \"vite,wrangler\" -c \"cyan,magenta\" \"vite\" \"wrangler pages dev --proxy 5173 --compatibility-date=2024-09-23 --port 8787\"",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "type-check": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply up-the-creek-orders --local",
    "db:migrate:remote": "wrangler d1 migrations apply up-the-creek-orders --remote"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "stripe": "^16.10.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.11",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "wrangler": "^4.105.0"
  }
}
